SUPABASE_DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000

# CORS Configuration
# Leave empty to allow cross-origin requests by default for non-credentialed
# clients. Set explicit origins in production if you want a tighter policy.
# http://localhost:3000 is always allowed for local dev.
CORS_ALLOWED_ORIGINS=
# Set to true only if your frontend sends cookies/HTTP auth cross-origin.
# When true, also set explicit CORS_ALLOWED_ORIGINS values.
CORS_ALLOW_CREDENTIALS=false

# Supabase Storage Configuration
SUPABASE_STORAGE_ENDPOINT=
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=
SUPABASE_STORAGE_REGION=

# Throttling Configuration
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_LOGIN_TTL_MS=60000
THROTTLE_AUTH_LOGIN_LIMIT=5
THROTTLE_AUTH_REFRESH_TTL_MS=60000
THROTTLE_AUTH_REFRESH_LIMIT=20
THROTTLE_AUTH_REGISTER_TTL_MS=60000
THROTTLE_AUTH_REGISTER_LIMIT=3
